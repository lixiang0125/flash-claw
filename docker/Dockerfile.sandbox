# FlashClaw 沙箱基础镜像
# 基于已下载的 open-webui 镜像
FROM ghcr.io/open-webui/open-webui:main

# 创建非 root 沙箱用户
RUN useradd --create-home --shell /bin/bash --uid 1000 sandbox || true

# 创建工作目录结构
RUN mkdir -p /workspace /tmp/sandbox \
    && chown -R sandbox:sandbox /workspace /tmp/sandbox

USER sandbox
WORKDIR /workspace

# 安全约束：容器启动后保持活跃，等待命令注入
CMD ["sleep", "infinity"]
