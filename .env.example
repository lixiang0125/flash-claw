OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
MODEL=qwen3.5-plus

FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
TAVILY_API_KEY=your-tavily-api-key

# ==================== mem0 记忆系统配置 ====================
# mem0 使用"LLM + Embedding"双服务架构：
#   - LLM      → 默认复用主 LLM 配置（OPENAI_API_KEY + OPENAI_BASE_URL + MODEL）
#   - Embedding → 默认使用本地 @xenova/transformers 模型，无需额外 API key
#
# ━━ LLM 配置（可选覆盖，不设则复用上方主 LLM 配置）━━
# MEM0_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# MEM0_LLM_MODEL=qwen3.5-plus

# ━━ Embedding 配置 ━━
# 默认 local 模式，使用本地 Xenova/multilingual-e5-small（384 维，~100MB ONNX）
# 首次运行会自动下载模型到 ~/.cache/
MEM0_EMBEDDING_MODE=local
# MEM0_LOCAL_MODEL=Xenova/multilingual-e5-small
# MEM0_EMBEDDING_DIMS=384

# ━━ 远程 Embedding（可选，将 MEM0_EMBEDDING_MODE 改为 remote 启用）━━
# MEMO_API_KEY=your-embedding-api-key
# MEM0_EMBEDDING_BASE_URL=https://api.minimax.io/v1
# MEM0_EMBEDDING_MODEL=embo-01
# MEM0_EMBEDDING_DIMS=1024
# MINIMAX_GROUP_ID=your-group-id
