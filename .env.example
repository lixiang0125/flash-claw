OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL=gpt-4o-mini

# ==================== 飞书机器人配置 ====================

# 方式1: Webhook (简单配置，只支持接收和回复消息)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 方式2: 开放平台 API (完整功能)
# FEISHU_APP_ID=your-app-id
# FEISHU_APP_SECRET=your-app-secret
# FEISHU_VERIFICATION_TOKEN=your-verification-token

# ==================== 其他配置 ====================
# 会话超时时间(秒)
SESSION_TIMEOUT=3600

# ==================== Docker 沙箱配置 ====================
# 是否使用 Docker 沙箱执行工具 (true/false)
USE_DOCKER_SANDBOX=false

# ==================== Tavily 搜索配置 ====================
TAVILY_API_KEY=your-tavily-api-key

# ==================== mem0 记忆系统配置 ====================
# mem0 使用 DashScope 通用端点（非 coding 端点）
# 如不配置，默认使用 https://dashscope.aliyuncs.com/compatible-mode/v1
# MEM0_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MEM0_LLM_MODEL=qwen-plus
# MEM0_EMBEDDING_MODEL=text-embedding-v3
# MEM0_EMBEDDING_DIMS=1024
